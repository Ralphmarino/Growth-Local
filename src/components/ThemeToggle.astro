---
const options = [
  {
    key: 'dark',
    label: 'Dark',
    // moon
    icon: '<path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.5 6.5 0 0 0 9.8 9.8Z"/>',
  },
  {
    key: 'evening',
    label: 'Evening',
    // sunset
    icon: '<path d="M12 9a4 4 0 0 0-4 4h8a4 4 0 0 0-4-4Z"/><path d="M2 17h20"/><path d="M12 3v1.5M5.2 6.8l1 1M18.8 6.8l-1 1"/>',
  },
  {
    key: 'light',
    label: 'Light',
    // sun
    icon: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5.6 5.6 4.2 4.2M19.8 19.8l-1.4-1.4M18.4 5.6l1.4-1.4M4.2 19.8l1.4-1.4"/>',
  },
];
---

<div class="theme-toggle inline-flex items-center gap-0.5 rounded-full border border-line p-0.5" role="group" aria-label="Color theme">
  {
    options.map((o) => (
      <button
        type="button"
        data-theme-set={o.key}
        class="flex h-7 w-7 items-center justify-center rounded-full text-ink-faint transition-colors hover:text-ink"
        title={`${o.label} mode`}
        aria-label={`${o.label} mode`}
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={o.icon} />
      </button>
    ))
  }
</div>

<style>
  .theme-toggle button[aria-pressed='true'] {
    background: rgb(var(--bg-700));
    color: rgb(var(--accent));
  }
</style>

<script>
  const root = document.documentElement;
  const btns = document.querySelectorAll<HTMLButtonElement>('[data-theme-set]');

  const sync = () => {
    const current = root.dataset.theme || 'dark';
    btns.forEach((b) =>
      b.setAttribute('aria-pressed', String(b.dataset.themeSet === current))
    );
  };

  btns.forEach((b) =>
    b.addEventListener('click', () => {
      const t = b.dataset.themeSet!;
      root.dataset.theme = t;
      try {
        localStorage.setItem('theme', t);
      } catch (e) {
        /* ignore */
      }
      sync();
    })
  );

  sync();
</script>
