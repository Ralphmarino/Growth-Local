---
// Ambient floating particles, scoped to this section only. Pure CSS
// transform/opacity animations (GPU-composited) keep it cheap. Positions and
// timings are hand-tuned; negative delays stagger them so they start mid-drift.
const particles = [
  { x: 8, y: 20, s: 3, dur: 11, delay: -2, tx: 14, ty: -22, op: 0.5 },
  { x: 18, y: 65, s: 2, dur: 14, delay: -6, tx: -10, ty: -18, op: 0.4 },
  { x: 26, y: 38, s: 4, dur: 9, delay: -1, tx: 12, ty: 20, op: 0.55 },
  { x: 33, y: 82, s: 2, dur: 13, delay: -9, tx: 16, ty: -14, op: 0.35 },
  { x: 42, y: 15, s: 3, dur: 12, delay: -4, tx: -14, ty: 24, op: 0.5 },
  { x: 50, y: 55, s: 5, dur: 10, delay: -7, tx: 10, ty: -26, op: 0.6 },
  { x: 58, y: 30, s: 2, dur: 15, delay: -3, tx: -12, ty: 18, op: 0.4 },
  { x: 66, y: 72, s: 3, dur: 11, delay: -10, tx: 14, ty: -20, op: 0.5 },
  { x: 74, y: 22, s: 4, dur: 9, delay: -5, tx: -16, ty: 22, op: 0.55 },
  { x: 82, y: 60, s: 2, dur: 14, delay: -2, tx: 12, ty: -16, op: 0.4 },
  { x: 90, y: 35, s: 3, dur: 12, delay: -8, tx: -10, ty: 20, op: 0.5 },
  { x: 14, y: 88, s: 2, dur: 13, delay: -11, tx: 16, ty: -22, op: 0.35 },
  { x: 38, y: 48, s: 2, dur: 16, delay: -4, tx: -14, ty: -18, op: 0.4 },
  { x: 60, y: 90, s: 3, dur: 10, delay: -6, tx: 12, ty: -24, op: 0.45 },
  { x: 70, y: 48, s: 2, dur: 15, delay: -1, tx: -12, ty: 20, op: 0.4 },
  { x: 94, y: 78, s: 3, dur: 11, delay: -9, tx: -14, ty: -18, op: 0.45 },
  { x: 4, y: 52, s: 2, dur: 14, delay: -5, tx: 14, ty: 16, op: 0.4 },
  { x: 48, y: 75, s: 4, dur: 10, delay: -3, tx: -10, ty: -22, op: 0.55 },
];
---

<section class="relative overflow-hidden border-t border-line py-[clamp(5rem,12vw,11rem)]">
  <!-- Floating lime particles (decorative) -->
  <div class="v-particles" aria-hidden="true">
    {
      particles.map((p) => (
        <span
          class="v-dot"
          style={`left:${p.x}%;top:${p.y}%;--s:${p.s}px;--d:${p.dur}s;--delay:${p.delay}s;--tx:${p.tx}px;--ty:${p.ty}px;--op:${p.op}`}
        />
      ))
    }
  </div>

  <div class="container-wide relative z-10 grid gap-10 md:grid-cols-12">
    <div class="md:col-span-3">
      <p class="eyebrow reveal sticky top-28">
        <span class="text-accent">[*]</span> &nbsp;Our Vision
      </p>
    </div>
    <div class="md:col-span-9">
      <h2 class="display text-balance text-[clamp(1.7rem,4.2vw,3.6rem)] leading-[1.1] tracking-tightest">
        <span class="line-mask"><span>To be the most trusted name in</span></span>
        <span class="line-mask"><span>digital marketing & web development,</span></span>
        <span class="line-mask"><span>for <span class="text-accent">local businesses</span> and</span></span>
        <span class="line-mask"><span>global brands alike.</span></span>
      </h2>
      <p class="reveal mt-10 max-w-2xl text-pretty text-lg leading-relaxed text-ink-muted">
        We work alongside our clients to deliver a full range of services for
        anyone looking to grow in the digital world. Through research, execution,
        and honest assessment, we build strategies that drive real progress and
        partnerships that last.
      </p>
    </div>
  </div>

  <style>
    .v-particles {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
      pointer-events: none;
    }
    .v-dot {
      position: absolute;
      width: var(--s);
      height: var(--s);
      border-radius: 999px;
      background: rgb(var(--lime));
      box-shadow: 0 0 6px 1px rgb(var(--lime) / 0.45);
      opacity: 0;
      will-change: transform, opacity;
      animation: vFloat var(--d) ease-in-out var(--delay) infinite;
    }
    @keyframes vFloat {
      0%,
      100% {
        transform: translate(0, 0);
        opacity: 0;
      }
      20% {
        opacity: var(--op);
      }
      50% {
        transform: translate(var(--tx), var(--ty));
        opacity: var(--op);
      }
      80% {
        opacity: var(--op);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .v-dot {
        animation: none;
        opacity: calc(var(--op) * 0.5);
      }
    }
  </style>
</section>
