---
// Quotes use <em> to mark the lime-accented phrase (styled below, not italic).
const testimonials = [
  {
    quote:
      "We've been working with Ralph and his team for years now. The progress has been <em>amazing</em> and I can always count on them to deliver. Love meeting and collaborating with Growth Local.",
    name: 'Jack & Joe Napoli',
    role: 'Founders · Analog Alien Guitar Pedals & Cloud 9 Recording Studio',
    links: [
      { label: 'analogalien.com', href: 'https://analogalien.com/' },
      { label: 'cloud9recording.com', href: 'https://cloud9recording.com/' },
    ],
  },
  {
    quote:
      'After going through several different companies, working with Growth Local has been <em>the absolute best</em>. Their knowledge, creativity, and service allowed us to truly explode in our SEO efforts. It’s more than just doing what should be done; it’s the creative foresight to proactively position our site that has really impressed us. I wish we would have found them sooner.',
    name: 'Greg Radcliffe',
    role: 'National Director of Operations · Bail Agent Network',
    links: [{ label: 'bailagentnetwork.com', href: 'https://www.bailagentnetwork.com/' }],
  },
  {
    quote:
      'This team really took my traffic & sales to the next level. <em>Whatever they do 100% works!</em>',
    name: 'Jaelen Strong',
    role: 'Former NFL Player · Founder, Concrete Flower (CBD)',
  },
  {
    quote:
      'My business had a big project to get off a limiting CMS and into WordPress. They <em>ensured success</em> and have been on my side since!!',
    name: 'Corri Moore',
    role: 'Actor, Model & Author · Founder, Amoregal Boutique',
  },
  {
    quote:
      'Ralph and the whole Growth Local team is amazing! Since they have been involved in the business I work with, our website and all around web presence has <em>improved and grown</em>. They are very knowledgeable and friendly and will not let you down!',
    name: 'Gina Ilasi',
    role: 'Social Media Manager',
  },
];
---

<section class="border-t border-line py-[clamp(5rem,12vw,10rem)]">
  <div class="container-wide">
    <div class="t-slider mx-auto max-w-5xl text-center" data-tslider>
      <p class="eyebrow reveal mb-10 flex items-center justify-center gap-3">
        <span class="inline-block h-px w-10 bg-lime"></span>
        What clients say
        <span class="font-mono text-ink-faint" data-tcount>01 / {testimonials.length}</span>
      </p>

      <!-- Slides stacked in one grid cell; the tallest sets the height -->
      <div class="grid">
        {
          testimonials.map((t, i) => (
            <figure
              class:list={['t-slide col-start-1 row-start-1 self-center', i === 0 && 'is-active']}
              data-tslide={i}
              aria-hidden={i !== 0 ? 'true' : 'false'}
            >
              <blockquote
                class="t-quote display text-balance text-[clamp(1.5rem,4.2vw,3.2rem)] leading-[1.12] tracking-tightest"
                set:html={`&ldquo;${t.quote}&rdquo;`}
              />
              <figcaption class="mt-8 font-mono text-sm">
                <span class="uppercase tracking-[0.14em] text-accent">— {t.name}</span>
                <span class="mt-2 block text-ink-muted">{t.role}</span>
                {t.links && (
                  <span class="mt-3 flex flex-wrap items-center justify-center gap-x-5 gap-y-1">
                    {t.links.map((l) => (
                      <a
                        href={l.href}
                        target="_blank"
                        rel="noopener"
                        class="text-[0.72rem] lowercase tracking-wider text-ink-faint underline-offset-4 transition-colors hover:text-accent hover:underline"
                      >
                        {l.label} ↗
                      </a>
                    ))}
                  </span>
                )}
              </figcaption>
            </figure>
          ))
        }
      </div>

      <!-- Controls -->
      <div class="mt-12 flex items-center justify-center gap-5">
        <button
          type="button"
          data-tprev
          class="flex h-11 w-11 items-center justify-center rounded-full border border-line text-ink-muted transition-colors hover:border-accent/50 hover:text-accent"
          aria-label="Previous testimonial"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <div class="flex items-center gap-2.5" role="tablist" aria-label="Choose testimonial">
          {
            testimonials.map((_, i) => (
              <button
                type="button"
                data-tdot={i}
                class="t-dot h-2 w-2 rounded-full bg-ink-faint/50 transition-all duration-300"
                aria-label={`Go to testimonial ${i + 1}`}
              />
            ))
          }
        </div>

        <button
          type="button"
          data-tnext
          class="flex h-11 w-11 items-center justify-center rounded-full border border-line text-ink-muted transition-colors hover:border-accent/50 hover:text-accent"
          aria-label="Next testimonial"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

      <!-- Auto-advance progress bar -->
      <div class="mx-auto mt-7 h-px w-40 overflow-hidden bg-line">
        <div class="t-progress h-full w-full origin-left bg-accent" data-tprogress></div>
      </div>
    </div>
  </div>

  <style>
    .t-slide {
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 0.6s var(--ease-out),
        transform 0.6s var(--ease-out);
      pointer-events: none;
    }
    .t-slide.is-active {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }
    .t-quote :global(em) {
      font-style: normal;
      color: rgb(var(--accent));
    }
    .t-dot.is-active {
      width: 1.6rem;
      background: rgb(var(--accent));
    }
    .t-progress {
      transform: scaleX(0);
    }
    .t-progress.run {
      transform: scaleX(1);
      transition: transform var(--t-dur, 7s) linear;
    }
  </style>

  <script>
    const root = document.querySelector<HTMLElement>('[data-tslider]');
    if (root) {
      const slides = [...root.querySelectorAll<HTMLElement>('[data-tslide]')];
      const dots = [...root.querySelectorAll<HTMLElement>('[data-tdot]')];
      const progress = root.querySelector<HTMLElement>('[data-tprogress]');
      const counter = root.querySelector<HTMLElement>('[data-tcount]');
      const DUR = 7000;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let i = 0;
      let timer: ReturnType<typeof setTimeout> | undefined;
      let paused = false;

      const pad = (n: number) => String(n).padStart(2, '0');

      const render = () => {
        slides.forEach((s, n) => {
          const on = n === i;
          s.classList.toggle('is-active', on);
          s.setAttribute('aria-hidden', on ? 'false' : 'true');
        });
        dots.forEach((d, n) => {
          const on = n === i;
          d.classList.toggle('is-active', on);
          d.setAttribute('aria-selected', String(on));
        });
        if (counter) counter.textContent = `${pad(i + 1)} / ${pad(slides.length)}`;
      };

      const runProgress = () => {
        if (!progress || reduced) return;
        // clear any inline freeze left by pause()
        progress.style.transition = '';
        progress.style.transform = '';
        progress.style.setProperty('--t-dur', `${DUR}ms`);
        progress.classList.remove('run');
        // force reflow so the transition restarts
        void progress.offsetWidth;
        progress.classList.add('run');
      };

      const schedule = () => {
        clearTimeout(timer);
        if (reduced || paused) return;
        runProgress();
        timer = setTimeout(() => go(i + 1), DUR);
      };

      const go = (n: number) => {
        i = (n + slides.length) % slides.length;
        render();
        schedule();
      };

      root.querySelector('[data-tnext]')?.addEventListener('click', () => go(i + 1));
      root.querySelector('[data-tprev]')?.addEventListener('click', () => go(i - 1));
      dots.forEach((d, n) => d.addEventListener('click', () => go(n)));

      // Pause on hover / focus
      const pause = () => {
        paused = true;
        clearTimeout(timer);
        if (progress) {
          const w = getComputedStyle(progress).transform;
          progress.style.transition = 'none';
          progress.style.transform = w;
        }
      };
      const resume = () => {
        paused = false;
        schedule();
      };
      root.addEventListener('mouseenter', pause);
      root.addEventListener('mouseleave', resume);
      root.addEventListener('focusin', pause);
      root.addEventListener('focusout', resume);

      render();
      schedule();
    }
  </script>
</section>
