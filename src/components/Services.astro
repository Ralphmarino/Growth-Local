---
interface Service {
  no: string;
  title: string;
  blurb: string;
  tags: string[];
  href?: string;
}

const services: Service[] = [
  {
    no: '01',
    title: 'Web Development',
    blurb:
      'Sites and platforms engineered to perform. Fast, accessible, and built to scale, from editorial marketing sites to full web applications.',
    tags: ['Next.js / Astro', 'Headless CMS', 'Web Apps', 'Core Web Vitals'],
  },
  {
    no: '02',
    title: 'AI Consulting',
    blurb:
      'Practical AI that moves the needle. We design and ship automations, assistants, and data workflows your team will actually use. No hype, just leverage.',
    tags: ['LLM Integration', 'Automation', 'RAG & Search', 'Strategy'],
  },
  {
    no: '03',
    title: 'SEO',
    href: '/services/seo',
    blurb:
      'Visibility that compounds. A full-funnel program: audits, technical, on-page, off-page, CRO, reporting, and AI search (GEO/AEO). It puts you in front of the people already looking.',
    tags: ['Audit', 'Technical', 'On-Page', 'Off-Page', 'CRO', 'Reporting', 'GEO/AEO'],
  },
  {
    no: '04',
    title: 'Digital Marketing',
    blurb:
      'Campaigns that convert. Paid, social, email, and analytics working as one system, pointed at measurable, durable growth.',
    tags: ['Paid Media', 'Lifecycle', 'Analytics', 'Conversion'],
  },
];
---

<section id="services" class="border-t border-line py-[clamp(4rem,9vw,8rem)]">
  <div class="container-wide">
    <div class="mb-12 flex flex-wrap items-end justify-between gap-6 md:mb-16">
      <h2 class="display text-[clamp(2.2rem,6.5vw,5.5rem)]">
        <span class="line-mask"><span>What we do</span></span>
      </h2>
      <p class="eyebrow reveal mb-3">
        <span class="text-accent">[02]</span> &nbsp;Capabilities / Four disciplines, one team
      </p>
    </div>

    <ul class="border-t border-line">
      {
        services.map((s) => {
          const Tag = s.href ? 'a' : 'div';
          return (
            <li class="group relative border-b border-line">
              <Tag
                {...(s.href ? { href: s.href } : {})}
                class="reveal grid grid-cols-12 items-center gap-4 py-7 transition-colors duration-500 md:py-9"
              >
                <span class="col-span-2 font-mono text-sm text-ink-faint transition-colors duration-300 group-hover:text-accent md:col-span-1">
                  {s.no}
                </span>
                <h3 class="display col-span-10 flex items-center gap-3 text-[clamp(1.9rem,5.2vw,4rem)] leading-none text-ink transition-transform duration-500 group-hover:translate-x-2 group-hover:text-accent md:col-span-6">
                  {s.title}
                  {s.href && (
                    <svg class="h-5 w-5 shrink-0 -translate-x-2 opacity-0 transition-all duration-500 group-hover:translate-x-0 group-hover:opacity-100" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 11L11 3M11 3H4.5M11 3V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  )}
                </h3>
                <div class="col-span-12 md:col-span-5">
                  {/* Desktop: reveal blurb + tags on hover. Fully hidden on
                      mobile (hidden) so a touch-triggered :hover can't duplicate
                      the always-visible mobile content below. */}
                  <div class="hidden md:block">
                    <div class="max-h-0 overflow-hidden opacity-0 transition-all duration-500 ease-out group-hover:max-h-56 group-hover:opacity-100">
                      <p class="text-pretty pt-1 leading-relaxed text-ink-muted">
                        {s.blurb}
                      </p>
                      <div class="mt-4 flex flex-wrap gap-2">
                        {s.tags.map((t) => (
                          <span class="rounded-full border border-line px-3 py-1 font-mono text-[0.68rem] uppercase tracking-wide text-ink-muted">
                            {t}
                          </span>
                        ))}
                      </div>
                      {s.href && (
                        <span class="mt-5 inline-flex font-mono text-[0.72rem] uppercase tracking-[0.14em] text-accent">
                          Explore SEO services →
                        </span>
                      )}
                    </div>
                  </div>

                  {/* Mobile: blurb + tags always visible (no hover on touch) */}
                  <div class="md:hidden">
                    <p class="text-pretty pt-1 leading-relaxed text-ink-muted">
                      {s.blurb}
                    </p>
                    <div class="mt-4 flex flex-wrap gap-2">
                      {s.tags.map((t) => (
                        <span class="rounded-full border border-line px-3 py-1 font-mono text-[0.68rem] uppercase tracking-wide text-ink-muted">
                          {t}
                        </span>
                      ))}
                    </div>
                    {s.href && (
                      <span class="mt-5 inline-flex font-mono text-[0.72rem] uppercase tracking-[0.14em] text-accent">
                        Explore SEO services →
                      </span>
                    )}
                  </div>
                </div>
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
