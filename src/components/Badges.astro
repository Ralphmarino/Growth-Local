---
// Credibility badges. Kept deliberately muted (desaturated + dimmed) so they
// blend into the dark UI, then come to full colour on hover.
const partners = [
  { src: '/badges/google-premier-partner.webp', alt: 'Google Premier Partner', href: 'https://www.google.com/partners/' },
  { src: '/badges/clutch.webp', alt: 'Clutch, view Growth Local profile', href: 'https://clutch.co/profile/growth-local' },
  { src: '/badges/goodfirms.png', alt: 'GoodFirms, view Growth Local profile', href: 'https://www.goodfirms.co/company/growth-local' },
  { src: '/badges/veteran-owned-business.png', alt: 'Veteran-Owned Business', href: null },
];

const awards = [
  { src: '/badges/expertise-2025.png', alt: 'Expertise.com, Best Digital Marketing Agencies in Colorado Springs 2025', href: null },
  { src: '/badges/top-10-seo-firm.png', alt: 'Best in Search, Top 10 SEO Firm', href: null },
  { src: '/badges/upcity-top-seo.webp', alt: 'UpCity, Top SEO Agency', href: null },
  { src: '/badges/top-seo-company.webp', alt: 'Top SEO Company, Colorado', href: null },
  { src: '/badges/top-digital-marketing.png', alt: 'Top Digital Marketing Company, Clutch', href: null },
];

const groups = [
  {
    label: 'Partners & Accreditations',
    items: partners,
    chip: 'h-24 px-6',
    img: 'max-h-14',
  },
  {
    label: 'Awards & Recognition',
    items: awards,
    chip: 'h-32 px-7 md:h-36 md:px-8',
    img: 'max-h-20 md:max-h-24',
  },
];
---

<section class="border-t border-line py-[clamp(3rem,6vw,5rem)]">
  <div class="container-wide space-y-10 md:space-y-12">
    {
      groups.map((g) => (
        <div>
          <p class="eyebrow reveal mb-6 text-center md:text-left">{g.label}</p>
          <ul class="flex flex-wrap items-center justify-center gap-3 md:justify-start md:gap-4">
            {g.items.map((b) => {
              const Tag = b.href ? 'a' : 'div';
              return (
                <li>
                  <Tag
                    {...(b.href ? { href: b.href, target: '_blank', rel: 'noopener' } : {})}
                    class:list={[
                      'group flex items-center justify-center rounded-xl border border-line bg-base-800/40 transition-all duration-300 hover:-translate-y-0.5 hover:border-accent/40 hover:bg-base-700/60',
                      g.chip,
                    ]}
                    aria-label={b.alt}
                  >
                    <img
                      src={b.src}
                      alt={b.alt}
                      loading="lazy"
                      class:list={[
                        'w-auto opacity-60 grayscale transition-all duration-300 group-hover:opacity-100 group-hover:grayscale-0',
                        g.img,
                      ]}
                    />
                  </Tag>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </div>
</section>
