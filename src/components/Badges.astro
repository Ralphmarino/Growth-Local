---
// Credibility badges. Kept deliberately muted (desaturated + dimmed) so they
// blend into the dark UI, then come to full colour on hover.
const partners = [
  { src: '/badges/google-premier-partner.webp', alt: 'Google Premier Partner', href: 'https://www.google.com/partners/' },
  { src: '/badges/clutch.webp', alt: 'Clutch — view Growth Local profile', href: 'https://clutch.co/profile/growth-local' },
  { src: '/badges/goodfirms.png', alt: 'GoodFirms — view Growth Local profile', href: 'https://www.goodfirms.co/company/growth-local' },
  { src: '/badges/veteran-owned-business.png', alt: 'Veteran-Owned Business', href: null },
];

// Award badges — add files to /public/badges and entries here once available:
//   badge-top-seo-company-colorado-gray, expertise-2025-best-seo-agency-colorado-springs,
//   top-10-seo-firm-growth-local, top-seo-agency-upcity, top-digital-marketing-agency-growth-local
const awards: { src: string; alt: string; href: string | null }[] = [];

const all = [...partners, ...awards];
---

<section class="border-t border-line py-[clamp(2.5rem,5vw,4rem)]">
  <div class="container-wide">
    <p class="eyebrow reveal mb-8 text-center md:text-left">
      Accredited &amp; recognized · Veteran-owned
    </p>
    <ul class="flex flex-wrap items-center justify-center gap-3 md:justify-start md:gap-4">
      {
        all.map((b) => {
          const Tag = b.href ? 'a' : 'div';
          return (
            <li>
              <Tag
                {...(b.href ? { href: b.href, target: '_blank', rel: 'noopener' } : {})}
                class="group flex h-14 items-center justify-center rounded-lg border border-line bg-base-800/40 px-5 transition-all duration-300 hover:-translate-y-0.5 hover:border-line hover:bg-base-700/60"
                aria-label={b.alt}
              >
                <img
                  src={b.src}
                  alt={b.alt}
                  loading="lazy"
                  class="max-h-7 w-auto opacity-50 grayscale transition-all duration-300 group-hover:opacity-100 group-hover:grayscale-0"
                />
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
