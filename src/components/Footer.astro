---
const isHome = Astro.url.pathname === '/';
const a = (hash: string) => (isHome ? hash : `/${hash}`);

const year = new Date().getFullYear();
const nav = [
  { label: 'Work', href: a('#work') },
  { label: 'Services', href: a('#services') },
  { label: 'SEO', href: '/services/seo' },
  { label: 'Studio', href: a('#studio') },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: a('#contact') },
];
const social = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/company/growthlocal/' },
  { label: 'Instagram', href: 'https://www.instagram.com/growthlocal/' },
  { label: 'Facebook', href: 'https://www.facebook.com/growthlocal' },
];
---

<footer class="border-t border-line">
  <div class="container-wide py-14 md:py-20">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <a href="/" class="group flex items-center gap-2">
          <span class="text-accent transition-transform duration-300 group-hover:-rotate-12">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11 21A8 8 0 0 1 9.5 5.3C16 4 18 3.4 20.5 1c1.2 2.4 2 4.9 2 9 0 6.1-5.1 11-11.5 11Z"/><path d="M3 22c0-3.5 2.2-6.2 6-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </span>
          <span class="font-display text-xl font-bold tracking-tightest">Growth&nbsp;Local</span>
        </a>
        <p class="mt-6 max-w-sm text-pretty leading-relaxed text-ink-muted">
          A digital studio in Colorado Springs building web, AI, and growth
          systems for ambitious brands nationwide.
        </p>
      </div>

      <nav class="md:col-span-3" aria-label="Footer">
        <p class="eyebrow mb-5">Sitemap</p>
        <ul class="space-y-3">
          {nav.map((l) => (
            <li>
              <a href={l.href} class="text-ink-muted transition-colors hover:text-accent">{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="md:col-span-2">
        <p class="eyebrow mb-5">Social</p>
        <ul class="space-y-3">
          {social.map((l) => (
            <li>
              <a href={l.href} target="_blank" rel="noopener" class="text-ink-muted transition-colors hover:text-accent">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <p class="eyebrow mb-5">Studio</p>
        <address class="space-y-3 not-italic text-ink-muted">
          <p>Colorado Springs, CO</p>
          <a href="mailto:contact@growthlocal.com" class="block transition-colors hover:text-accent">contact@growthlocal.com</a>
          <a href="tel:+16786316518" class="block transition-colors hover:text-accent">678-631-6518</a>
        </address>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-line pt-8 font-mono text-[0.72rem] uppercase tracking-wider text-ink-faint md:flex-row md:items-center">
      <p>© {year} Growth Local. All rights reserved.</p>
      <p class="flex items-center gap-2">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-lime"></span>
        Local roots · National reach
      </p>
    </div>
  </div>
</footer>
