---
const isHome = Astro.url.pathname === '/';
const a = (hash: string) => (isHome ? hash : `/${hash}`);

const year = new Date().getFullYear();
const nav = [
  { label: 'Work', href: a('#work') },
  { label: 'Services', href: a('#services') },
  { label: 'SEO', href: '/services/seo' },
  { label: 'Studio', href: a('#studio') },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: a('#contact') },
];
const social = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/company/growthlocal/',
    svg: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.8 0 0 .78 0 1.73v20.54C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .78 23.2 0 22.22 0z"/></svg>',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/growthlocal/',
    svg: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.43-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07c-1.27.06-2.15.26-2.91.56-.79.3-1.46.72-2.13 1.38A5.9 5.9 0 0 0 .63 4.14c-.3.76-.5 1.64-.56 2.91C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.3.79.72 1.46 1.38 2.13.67.66 1.34 1.08 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.9 5.9 0 0 0 2.13-1.38 5.9 5.9 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.9 5.9 0 0 0-1.38-2.13A5.9 5.9 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0z"/><path d="M12 5.84A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84zM12 16a4 4 0 1 1 4-4 4 4 0 0 1-4 4z"/><circle cx="18.41" cy="5.59" r="1.44"/></svg>',
  },
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/growthlocal',
    svg: '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.96H15.83c-1.49 0-1.95.93-1.95 1.87v2.25h3.32l-.53 3.49h-2.79V24C19.61 23.1 24 18.1 24 12.07z"/></svg>',
  },
];

const iconEnvelope =
  '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m3.5 7 8.5 6 8.5-6" stroke-linecap="round" stroke-linejoin="round"/></svg>';
const iconPhone =
  '<svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.6a1 1 0 0 1-.25 1l-2.2 2.2z"/></svg>';
const iconPin =
  '<svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z"/></svg>';
---

<footer class="border-t border-line">
  <div class="container-wide py-14 md:py-20">
    <div class="grid gap-x-8 gap-y-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <a href="/" class="group flex items-center gap-2">
          <span class="text-accent transition-transform duration-300 group-hover:-rotate-12">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11 21A8 8 0 0 1 9.5 5.3C16 4 18 3.4 20.5 1c1.2 2.4 2 4.9 2 9 0 6.1-5.1 11-11.5 11Z"/><path d="M3 22c0-3.5 2.2-6.2 6-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </span>
          <span class="font-display text-xl font-bold tracking-tightest">Growth&nbsp;Local</span>
        </a>
        <p class="mt-6 max-w-sm text-pretty leading-relaxed text-ink-muted">
          A digital studio in Colorado Springs building web, AI, and growth
          systems for ambitious brands nationwide.
        </p>
      </div>

      <nav class="md:col-span-2" aria-label="Footer">
        <p class="eyebrow mb-5">Sitemap</p>
        <ul class="space-y-3">
          {nav.map((l) => (
            <li>
              <a href={l.href} class="text-ink-muted transition-colors hover:text-accent">{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="md:col-span-2">
        <p class="eyebrow mb-5">Social</p>
        <ul class="space-y-2.5">
          {social.map((l) => (
            <li>
              <a
                href={l.href}
                target="_blank"
                rel="noopener"
                class="group inline-flex items-center gap-3 text-ink-muted transition-colors hover:text-accent"
              >
                <span
                  class="grid h-9 w-9 shrink-0 place-items-center rounded-lg border border-line text-ink-muted transition-all duration-300 group-hover:-translate-y-0.5 group-hover:border-accent/50 group-hover:bg-accent/5 group-hover:text-accent"
                  set:html={l.svg}
                />
                <span>{l.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-4">
        <p class="eyebrow mb-5">Studio</p>
        <address class="space-y-3.5 not-italic text-ink-muted">
          <p class="flex items-center gap-2.5">
            <span class="shrink-0 text-accent" set:html={iconPin} />
            Colorado Springs, CO
          </p>
          <a href="mailto:contact@growthlocal.com" class="group flex items-center gap-2.5 transition-colors hover:text-accent">
            <span class="shrink-0 text-accent" set:html={iconEnvelope} />
            contact@growthlocal.com
          </a>
          <a href="sms:+16786316518" class="group flex items-center gap-2.5 transition-colors hover:text-accent">
            <span class="shrink-0 text-accent" set:html={iconPhone} />
            <span><span class="text-accent">Call or text</span> <span class="whitespace-nowrap">678-631-6518</span></span>
          </a>
        </address>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start gap-5 border-t border-line pt-8 font-mono text-[0.72rem] uppercase tracking-wider text-ink-faint lg:flex-row lg:items-center lg:justify-between">
      <p class="flex flex-wrap items-center gap-x-2 gap-y-1">
        <span>© {year} Growth Local. All rights reserved.</span>
      </p>

      <!-- For the robots / AI -->
      <p class="flex flex-wrap items-center gap-x-2 gap-y-1">
        <span class="text-accent">For the robots&nbsp;🤖</span>
        <a href="/sitemap-index.xml" class="underline-offset-4 transition-colors hover:text-accent hover:underline">Sitemap</a>
        <span aria-hidden="true">·</span>
        <a href="/llms.txt" class="underline-offset-4 transition-colors hover:text-accent hover:underline">llms.txt</a>
      </p>

      <!-- Fun easter-egg message for the humans who scrolled this far -->
      <p class="flex items-center gap-2 normal-case tracking-normal">
        You made it this far, you're awesome
        <span class="glow-smile" aria-hidden="true">😎</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .glow-smile {
    display: inline-block;
    filter: drop-shadow(0 0 6px rgb(var(--lime) / 0.9))
      drop-shadow(0 0 14px rgb(var(--lime) / 0.5));
    animation: glowPulse 2.8s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%, 100% {
      filter: drop-shadow(0 0 5px rgb(var(--lime) / 0.7))
        drop-shadow(0 0 12px rgb(var(--lime) / 0.4));
      transform: translateY(0);
    }
    50% {
      filter: drop-shadow(0 0 9px rgb(var(--lime) / 1))
        drop-shadow(0 0 20px rgb(var(--lime) / 0.6));
      transform: translateY(-2px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .glow-smile { animation: none; }
  }
</style>
