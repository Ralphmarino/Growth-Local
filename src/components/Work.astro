---
// Real clients. `slug` is reserved for future internal case-study pages
// (/work/<slug>); for now each links out to the live site.
const clients = [
  {
    name: 'Analog Alien & Cloud 9 Recording',
    slug: 'analog-alien-cloud-9',
    summary: 'Full partnership — SEO, GEO, web & social.',
    tags: ['SEO', 'GEO', 'Web', 'Social'],
    links: [
      { label: 'analogalien.com', href: 'https://analogalien.com/' },
      { label: 'cloud9recording.com', href: 'https://cloud9recording.com/' },
    ],
  },
  {
    name: 'Yes Energy',
    slug: 'yes-energy',
    summary: 'SEO, site-migration assistance, retention & migration mitigation.',
    tags: ['SEO', 'Migration', 'Retention'],
    links: [{ label: 'yesenergy.com', href: 'https://www.yesenergy.com/' }],
  },
  {
    name: 'Bail Agent Network',
    slug: 'bail-agent-network',
    summary: 'SEO, GEO, and ongoing website & directory maintenance.',
    tags: ['SEO', 'GEO', 'Maintenance'],
    links: [{ label: 'bailagentnetwork.com', href: 'https://www.bailagentnetwork.com/' }],
  },
  {
    name: 'Elixinol',
    slug: 'elixinol',
    summary: 'SEO & GEO optimization for a global wellness brand.',
    tags: ['SEO', 'GEO'],
    links: [{ label: 'elixinol.com', href: 'https://elixinol.com/' }],
  },
  {
    name: 'Kavasutra Kava Bars',
    slug: 'kavasutra',
    summary: 'SEO & GEO strategy and consulting.',
    tags: ['SEO', 'GEO', 'Consulting'],
    links: [{ label: 'kavasutra.com', href: 'https://www.kavasutra.com/' }],
  },
  {
    name: 'Love, Georgie',
    slug: 'love-georgie',
    summary: 'SEO & GEO optimization.',
    tags: ['SEO', 'GEO'],
    links: [{ label: 'lovegeorgie.com', href: 'https://lovegeorgie.com/' }],
  },
];
---

<section id="work" class="border-t border-line py-[clamp(4rem,9vw,8rem)]">
  <div class="container-wide">
    <div class="mb-12 flex flex-wrap items-end justify-between gap-6 md:mb-16">
      <h2 class="display text-[clamp(2.2rem,6.5vw,5.5rem)]">
        <span class="line-mask"><span>Selected work</span></span>
      </h2>
      <p class="eyebrow reveal mb-3">
        <span class="text-accent">[03]</span> &nbsp;Trusted by brands we've grown
      </p>
    </div>

    <ul class="border-t border-line">
      {
        clients.map((c) => (
          <li class="group border-b border-line">
            <div class="reveal grid grid-cols-12 items-baseline gap-x-4 gap-y-3 py-7 md:py-8">
              <div class="col-span-12 md:col-span-6">
                <a
                  href={c.links[0].href}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-3 transition-transform duration-300 hover:translate-x-1"
                >
                  <h3 class="display text-[clamp(1.5rem,3.6vw,2.7rem)] leading-none tracking-tightest transition-colors duration-300 group-hover:text-accent">
                    {c.name}
                  </h3>
                  <svg class="h-5 w-5 shrink-0 -translate-x-2 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 11L11 3M11 3H4.5M11 3V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </div>
              <div class="col-span-12 md:col-span-6 md:text-right">
                <p class="text-pretty leading-relaxed text-ink-muted">{c.summary}</p>
                <div class="mt-3 flex flex-wrap gap-2 md:justify-end">
                  {c.tags.map((t) => (
                    <span class="rounded-full border border-line px-3 py-1 font-mono text-[0.66rem] uppercase tracking-wide text-ink-muted">
                      {t}
                    </span>
                  ))}
                </div>
                <div class="mt-3 flex flex-wrap gap-x-5 gap-y-1 md:justify-end">
                  {c.links.map((l) => (
                    <a
                      href={l.href}
                      target="_blank"
                      rel="noopener"
                      class="font-mono text-[0.72rem] lowercase tracking-wider text-ink-faint underline-offset-4 transition-colors hover:text-accent hover:underline"
                    >
                      {l.label} ↗
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </li>
        ))
      }
    </ul>

    <p class="reveal mt-10 text-pretty text-ink-muted">
      In-depth case studies coming soon.{' '}
      <a href="#contact" class="text-accent underline-offset-4 hover:underline">
        Want to be next? Start a project →
      </a>
    </p>
  </div>
</section>
