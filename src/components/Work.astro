---
// Real clients. `logo` shows at rest on a per-brand tile (`tile`: dark for
// light/white logos, light for dark logos — fixed colors so they read in every
// theme). `shot` (the homepage screenshot) crossfades in on hover.
const clients = [
  {
    name: 'Analog Alien',
    slug: 'analog-alien',
    summary: 'SEO, GEO, web & social for the guitar-pedal brand.',
    tags: ['SEO', 'GEO', 'Web', 'Social'],
    logo: '/work/analog-alien-logo.png',
    tile: 'dark',
    shot: '/work/analog-alien-screenshot.png',
    links: [{ label: 'analogalien.com', href: 'https://analogalien.com/' }],
  },
  {
    name: 'Cloud 9 Recording',
    slug: 'cloud-9',
    summary: 'Search, web & social for the recording studio.',
    tags: ['SEO', 'GEO', 'Web', 'Social'],
    logo: '/work/cloud-9-logo.png',
    tile: 'dark',
    shot: '/work/cloud-9-screenshot.png',
    links: [{ label: 'cloud9recording.com', href: 'https://cloud9recording.com/' }],
  },
  {
    name: 'Elixinol',
    slug: 'elixinol',
    summary: 'SEO & GEO for a global wellness brand.',
    tags: ['SEO', 'GEO'],
    logo: '/work/elixinol-logo.png',
    tile: 'dark',
    shot: '/work/elixinol-screenshot.png',
    links: [{ label: 'elixinol.com', href: 'https://elixinol.com/' }],
  },
  {
    name: 'Yes Energy',
    slug: 'yes-energy',
    summary: 'SEO, site-migration assistance, retention & mitigation.',
    tags: ['SEO', 'Migration', 'Retention'],
    logo: '/work/yes-energy-logo.png',
    tile: 'light',
    shot: '/work/yes-energy-screenshot.png',
    links: [{ label: 'yesenergy.com', href: 'https://www.yesenergy.com/' }],
  },
  {
    name: 'Bail Agent Network',
    slug: 'bail-agent-network',
    summary: 'SEO, GEO, and ongoing website & directory maintenance.',
    tags: ['SEO', 'GEO', 'Maintenance'],
    logo: '/work/bail-agent-network-logo.png',
    tile: 'light',
    shot: '/work/bail-agent-network-screenshot.png',
    links: [{ label: 'bailagentnetwork.com', href: 'https://www.bailagentnetwork.com/' }],
  },
  {
    name: 'Love, Georgie',
    slug: 'love-georgie',
    summary: 'SEO & GEO optimization.',
    tags: ['SEO', 'GEO'],
    logo: '/work/love-georgie-logo.png',
    tile: 'light',
    shot: '/work/love-georgie-screenshot.png',
    links: [{ label: 'lovegeorgie.com', href: 'https://lovegeorgie.com/' }],
  },
];
---

<section id="work" class="border-t border-line py-[clamp(4rem,9vw,8rem)]">
  <div class="container-wide">
    <div class="mb-12 flex flex-wrap items-end justify-between gap-6 md:mb-16">
      <h2 class="display text-[clamp(2.2rem,6.5vw,5.5rem)]">
        <span class="line-mask"><span>Selected work</span></span>
      </h2>
      <p class="eyebrow reveal mb-3">
        <span class="text-accent">[03]</span> &nbsp;Trusted by brands we've grown
      </p>
    </div>

    <div class="grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        clients.map((c, i) => {
          const light = c.tile === 'light';
          return (
            <article class="reveal group" style={`--reveal-delay:${(i % 3) * 80}ms`}>
              <a href={c.links[0].href} target="_blank" rel="noopener" class="block" aria-label={c.name}>
                <div class:list={['relative aspect-[4/3] overflow-hidden rounded-xl border border-line', light ? 'bg-white' : 'bg-[#0d0d0f]']}>
                  <div class:list={['absolute inset-0', light ? 'work-grid-l' : 'work-grid-d']} aria-hidden="true" />
                  <img
                    src={c.logo}
                    alt={c.name}
                    loading="lazy"
                    class="absolute inset-0 m-auto max-h-[42%] max-w-[72%] object-contain transition-transform duration-500 group-hover:scale-[1.03]"
                  />
                  <img
                    src={c.shot}
                    alt={`${c.name} website`}
                    loading="lazy"
                    class="absolute inset-0 h-full w-full object-cover object-top opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                  />
                  <span class="absolute right-4 top-4 z-10 flex h-9 w-9 translate-y-1 items-center justify-center rounded-full bg-lime text-base-900 opacity-0 shadow-lg transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H4.5M11 3V9.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              </a>
              <div class="mt-4">
                <div class="flex items-baseline justify-between gap-3">
                  <h3 class="font-display text-xl font-semibold tracking-tightest transition-colors duration-300 group-hover:text-accent">
                    {c.name}
                  </h3>
                  {c.links.map((l) => (
                    <a
                      href={l.href}
                      target="_blank"
                      rel="noopener"
                      class="shrink-0 font-mono text-[0.68rem] lowercase tracking-wider text-ink-faint underline-offset-4 transition-colors hover:text-accent hover:underline"
                    >
                      {l.label} ↗
                    </a>
                  ))}
                </div>
                <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">{c.summary}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {c.tags.map((t) => (
                    <span class="rounded-full border border-line px-2.5 py-1 font-mono text-[0.62rem] uppercase tracking-wide text-ink-muted">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <p class="reveal mt-12 text-pretty text-ink-muted">
      In-depth case studies coming soon.{' '}
      <a href="#contact" class="text-accent underline-offset-4 hover:underline">
        Want to be next? Start a project →
      </a>
    </p>
  </div>

  <style>
    /* Same grid texture on both tile colours — light lines on dark, dark on white */
    .work-grid-d {
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
      background-size: 38px 38px;
    }
    .work-grid-l {
      background-image:
        linear-gradient(rgba(10, 10, 11, 0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(10, 10, 11, 0.06) 1px, transparent 1px);
      background-size: 38px 38px;
    }
  </style>
</section>
