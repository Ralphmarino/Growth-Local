---
import ThemeToggle from './ThemeToggle.astro';

const isHome = Astro.url.pathname === '/';
const a = (hash: string) => (isHome ? hash : `/${hash}`);

const links = [
  { label: 'Work', href: a('#work') },
  { label: 'Services', href: a('#services') },
  { label: 'SEO', href: '/services/seo' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: a('#contact') },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 transition-transform duration-500"
  data-nav
>
  <nav class="container-wide flex items-center justify-between py-5">
    <a href="/" class="group flex items-center gap-2" aria-label="Growth Local home">
      <span class="text-accent transition-transform duration-300 group-hover:-rotate-12">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11 21A8 8 0 0 1 9.5 5.3C16 4 18 3.4 20.5 1c1.2 2.4 2 4.9 2 9 0 6.1-5.1 11-11.5 11Z"/><path d="M3 22c0-3.5 2.2-6.2 6-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </span>
      <span class="font-display text-lg font-bold tracking-tightest">Growth&nbsp;Local</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="group relative font-mono text-[0.78rem] uppercase tracking-[0.12em] text-ink-muted transition-colors hover:text-ink"
          >
            {l.label}
            <span class="absolute -bottom-1.5 left-0 h-px w-0 bg-lime transition-all duration-300 group-hover:w-full" />
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a href={a('#contact')} class="btn btn-primary hidden md:inline-flex">
        Start a project
      </a>
      <a
        href={a('#contact')}
        class="btn btn-ghost md:hidden !px-4 !py-2 !text-[0.7rem]"
        aria-label="Start a project"
      >
        Start
      </a>
    </div>
  </nav>
</header>

<script>
  // Hide nav on scroll-down, reveal on scroll-up
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  let last = 0;
  if (nav) {
    window.addEventListener(
      'scroll',
      () => {
        const y = window.scrollY;
        if (y > 120 && y > last) nav.style.transform = 'translateY(-100%)';
        else nav.style.transform = 'translateY(0)';
        nav.style.backgroundColor =
          y > 40 ? 'rgba(10,10,11,0.72)' : 'transparent';
        nav.style.backdropFilter = y > 40 ? 'blur(12px)' : 'none';
        nav.style.borderBottom =
          y > 40 ? '1px solid rgba(244,244,239,0.08)' : '1px solid transparent';
        last = y;
      },
      { passive: true }
    );
  }
</script>
