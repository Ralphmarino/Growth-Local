---
---

<section id="top" class="relative flex min-h-[100svh] flex-col justify-end overflow-hidden pb-[clamp(2.5rem,6vw,5rem)] pt-32">
  <!-- Ambient lime glow, parallaxed -->
  <div
    class="pointer-events-none absolute -right-[10%] top-[8%] -z-0 h-[55vw] w-[55vw] rounded-full opacity-[0.16] blur-[120px]"
    style="background: radial-gradient(circle, #C7F94E 0%, transparent 62%);"
    data-parallax="0.18"
    aria-hidden="true"
  >
  </div>

  <div class="container-wide relative z-10">
    <p class="eyebrow reveal mb-8 flex items-center gap-3">
      <span class="inline-block h-px w-10 bg-lime"></span>
      Colorado Springs · Digital Studio · Est. 2020
    </p>

    <h1 class="display text-ink text-[clamp(2.9rem,11.5vw,12.5rem)]">
      <span class="line-mask"><span>Local roots.</span></span>
      <span class="line-mask"><span class="text-ink-muted">National <span class="text-lime">reach.</span></span></span>
    </h1>

    <div class="mt-10 grid items-end gap-8 md:mt-14 md:grid-cols-12">
      <p class="reveal col-span-12 max-w-xl text-pretty text-lg leading-relaxed text-ink-muted md:col-span-6 md:text-xl" style="--reveal-delay:120ms">
        We engineer high-performance websites, ship practical AI, and build
        marketing systems that compound — for ambitious brands far beyond the
        Front Range.
      </p>

      <div class="reveal col-span-12 flex flex-wrap items-center gap-4 md:col-span-6 md:justify-end" style="--reveal-delay:220ms">
        <a href="#contact" class="btn btn-primary">
          Start a project
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 11L11 3M11 3H4.5M11 3V9.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#work" class="btn btn-ghost">View selected work</a>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="container-wide reveal relative z-10 mt-14 hidden items-center gap-3 md:flex" style="--reveal-delay:320ms">
    <span class="eyebrow !text-ink-faint">Scroll</span>
    <span class="block h-10 w-px bg-gradient-to-b from-ink-faint to-transparent"></span>
  </div>
</section>
