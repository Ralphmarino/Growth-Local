---
import AuditForm from './AuditForm.astro';
---

<section id="contact" class="relative overflow-hidden border-t border-line py-[clamp(5rem,13vw,11rem)]">
  <div
    class="pointer-events-none absolute -bottom-[20%] left-1/2 -z-0 h-[60vw] w-[60vw] -translate-x-1/2 rounded-full opacity-[0.14] blur-[130px]"
    style="background: radial-gradient(circle, #C7F94E 0%, transparent 62%);"
    data-parallax="-0.12"
    aria-hidden="true"
  >
  </div>

  <div class="container-wide relative z-10">
    <p class="eyebrow reveal mb-8">
      <span class="text-accent">[05]</span> &nbsp;Start a project
    </p>

    <h2 class="display text-[clamp(2.6rem,9vw,9rem)]">
      <span class="line-mask"><span>Let's build</span></span>
      <span class="line-mask"><span>something that <span class="text-accent">grows.</span></span></span>
    </h2>

    <div class="mt-12 grid gap-10 border-t border-line pt-10 lg:grid-cols-12">
      <!-- Pitch + secondary contact -->
      <div class="reveal col-span-12 lg:col-span-5">
        <p class="eyebrow mb-4 flex items-center gap-3">
          <span class="inline-block h-px w-8 bg-lime"></span>
          Free SEO audit
        </p>
        <p class="max-w-md text-pretty text-lg leading-relaxed text-ink-muted">
          Drop your site in and we'll send a free, no-strings audit — the gaps,
          the quick wins, and the fastest credible path to growth. Tell us where
          you want to be in twelve months; we'll tell you how to get there.
        </p>

        <div class="mt-9">
          <p class="font-mono text-[0.7rem] uppercase tracking-wider text-ink-faint">Prefer to just reach out?</p>
          <div class="mt-3 space-y-2">
            <a href="sms:+16786316518" class="group flex items-center gap-2 text-lg text-ink transition-colors hover:text-accent">
              <span class="text-accent">Call or text</span> 678-631-6518
            </a>
            <a href="mailto:contact@growthlocal.com?subject=New%20project%20enquiry" class="block text-lg text-ink transition-colors hover:text-accent">
              contact@growthlocal.com
            </a>
          </div>
        </div>
      </div>

      <!-- Audit form card -->
      <div class="reveal col-span-12 lg:col-span-7 lg:justify-self-end lg:max-w-xl" style="--reveal-delay:120ms">
        <div class="rounded-2xl border border-line bg-base-900/50 p-6 backdrop-blur-sm md:p-8">
          <AuditForm />
        </div>
      </div>
    </div>
  </div>
</section>
