---
---

<section id="contact" class="relative overflow-hidden border-t border-line py-[clamp(5rem,13vw,11rem)]">
  <div
    class="pointer-events-none absolute -bottom-[20%] left-1/2 -z-0 h-[60vw] w-[60vw] -translate-x-1/2 rounded-full opacity-[0.14] blur-[130px]"
    style="background: radial-gradient(circle, #C7F94E 0%, transparent 62%);"
    data-parallax="-0.12"
    aria-hidden="true"
  >
  </div>

  <div class="container-wide relative z-10">
    <p class="eyebrow reveal mb-8">
      <span class="text-accent">[05]</span> &nbsp;Start a project
    </p>

    <h2 class="display text-[clamp(2.6rem,9vw,9rem)]">
      <span class="line-mask"><span>Let's build</span></span>
      <span class="line-mask"><span>something that <span class="text-accent">grows.</span></span></span>
    </h2>

    <div class="mt-12 grid gap-10 border-t border-line pt-10 md:grid-cols-12">
      <p class="reveal col-span-12 max-w-md text-pretty text-lg leading-relaxed text-ink-muted md:col-span-5">
        Tell us where you want to be in twelve months. We'll tell you the
        fastest credible path to get there — and whether we're the right team to
        build it.
      </p>

      <div class="reveal col-span-12 md:col-span-7 md:justify-self-end" style="--reveal-delay:120ms">
        <a
          href="mailto:contact@growthlocal.com?subject=New%20project%20enquiry"
          class="group flex items-center justify-between gap-6 border-b border-line py-6 transition-colors hover:border-lime"
        >
          <span class="font-display text-2xl tracking-tightest md:text-4xl">contact@growthlocal.com</span>
          <svg class="text-ink-muted transition-colors group-hover:text-accent" width="24" height="24" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 11L11 3M11 3H4.5M11 3V9.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a
          href="tel:+16786316518"
          class="group flex items-center justify-between gap-6 border-b border-line py-6 transition-colors hover:border-lime"
        >
          <span class="font-display text-2xl tracking-tightest md:text-4xl">678-631-6518</span>
          <svg class="text-ink-muted transition-colors group-hover:text-accent" width="24" height="24" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 11L11 3M11 3H4.5M11 3V9.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href="mailto:contact@growthlocal.com?subject=New%20project%20enquiry" class="btn btn-primary">
            Email the studio
          </a>
          <a href="tel:+16786316518" class="btn btn-ghost">Book a call</a>
        </div>
      </div>
    </div>
  </div>
</section>
