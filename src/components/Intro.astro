<section id="studio" class="container-wide py-[clamp(5rem,12vw,11rem)]">
  <div class="grid gap-10 md:grid-cols-12">
    <div class="md:col-span-3">
      <p class="eyebrow reveal sticky top-28">
        <span class="text-lime">[01]</span> &nbsp;The Studio
      </p>
    </div>
    <div class="md:col-span-9">
      <h2 class="display text-[clamp(1.8rem,4.6vw,4.1rem)] leading-[1.05] tracking-tightest">
