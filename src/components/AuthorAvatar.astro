---
import { ralph } from '../data/author';

interface Props {
  size?: number;
  class?: string;
}
const { size = 96, class: cls = '' } = Astro.props;
---

<span
  class:list={['avatar-swap', cls]}
  style={`--sz:${size}px`}
  aria-label={ralph.name}
  role="img"
>
  <img class="av av-memoji" src={ralph.memoji} alt="" width={size} height={size} loading="lazy" decoding="async" />
  <img class="av av-photo" src={ralph.photo} alt="" width={size} height={size} loading="lazy" decoding="async" />
</span>

<style>
  .avatar-swap {
    position: relative;
    display: inline-block;
    width: var(--sz);
    height: var(--sz);
    border-radius: 999px;
    padding: 3px;
    background:
      linear-gradient(140deg, #c7f94e, rgba(199, 249, 78, 0.25));
    box-shadow: 0 0 0 1px rgba(199, 249, 78, 0.25);
    flex: none;
  }
  .av {
    position: absolute;
    inset: 3px;
    width: calc(var(--sz) - 6px);
    height: calc(var(--sz) - 6px);
    border-radius: 999px;
    object-fit: cover;
    background: #0f0f11;
    transition:
      opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    backface-visibility: hidden;
  }
  /* Default (fine pointers): show the playful memoji, reveal the real photo on hover */
  .av-photo {
    opacity: 0;
    transform: scale(1.06);
  }
  .avatar-swap:hover .av-memoji {
    opacity: 0;
    transform: scale(0.96);
  }
  .avatar-swap:hover .av-photo {
    opacity: 1;
    transform: scale(1);
  }
  /* Touch devices can't hover — so gently auto-crossfade memoji <-> photo on a
     loop, giving mobile users the same playful reveal without a pointer. */
  @media (hover: none) {
    .av-memoji {
      animation: avFadeMemoji 6s ease-in-out infinite;
    }
    .av-photo {
      animation: avFadePhoto 6s ease-in-out infinite;
    }
  }
  @keyframes avFadeMemoji {
    0%, 38% { opacity: 1; transform: scale(1); }
    50%, 88% { opacity: 0; transform: scale(0.96); }
    100% { opacity: 1; transform: scale(1); }
  }
  @keyframes avFadePhoto {
    0%, 38% { opacity: 0; transform: scale(1.06); }
    50%, 88% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.06); }
  }
  @media (prefers-reduced-motion: reduce) {
    .av {
      transition: opacity 0.2s linear;
      transform: none !important;
    }
    /* No looping animation when motion is reduced — settle on the real photo */
    @media (hover: none) {
      .av-memoji { animation: none; opacity: 0; }
      .av-photo { animation: none; opacity: 1; transform: none; }
    }
  }
</style>
