---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base
  title="Blog — SEO, AI search & growth insights · Growth Local"
  description="Field notes on SEO, AI search (GEO/AEO), web performance, and growth from the Growth Local studio."
>
  <Nav />
  <main id="main">
    <section class="relative overflow-hidden pb-[clamp(2.5rem,6vw,5rem)] pt-36 md:pt-44">
      <div
        class="pointer-events-none absolute -right-[8%] top-0 -z-0 h-[46vw] w-[46vw] rounded-full opacity-[0.13] blur-[120px]"
        style="background: radial-gradient(circle, #C7F94E 0%, transparent 62%);"
        aria-hidden="true"
      >
      </div>
      <div class="container-wide relative z-10">
        <p class="eyebrow reveal mb-8 flex items-center gap-3">
          <span class="inline-block h-px w-10 bg-lime"></span>
          The Journal
        </p>
        <h1 class="display text-[clamp(2.6rem,9vw,8.5rem)]">
          <span class="line-mask"><span>Field notes on</span></span>
          <span class="line-mask"><span><span class="text-accent">growth.</span></span></span>
        </h1>
        <p class="reveal mt-8 max-w-xl text-lg leading-relaxed text-ink-muted" style="--reveal-delay:120ms">
          Practical thinking on SEO, AI search, performance, and the craft of
          building things that compound.
        </p>
      </div>
    </section>

    <section class="border-t border-line py-[clamp(2.5rem,6vw,5rem)]">
      <div class="container-wide">
        <ul class="border-t border-line">
          {
            posts.map((post, i) => (
              <li class="group border-b border-line">
                <a
                  href={`/blog/${post.slug}`}
                  class="reveal grid grid-cols-12 items-baseline gap-4 py-8 transition-colors md:py-10"
                  style={`--reveal-delay:${(i % 3) * 70}ms`}
                >
                  <div class="col-span-12 flex items-center gap-4 md:col-span-3">
                    <span class="font-mono text-[0.72rem] uppercase tracking-wider text-accent">
                      {post.data.category}
                    </span>
                    <span class="font-mono text-[0.72rem] text-ink-faint">
                      {fmt(post.data.pubDate)}
                    </span>
                  </div>
                  <div class="col-span-12 md:col-span-9">
                    <h2 class="font-display text-[clamp(1.5rem,3.4vw,2.6rem)] font-semibold leading-tight tracking-tightest transition-colors duration-300 group-hover:text-accent">
                      {post.data.title}
                    </h2>
                    <p class="mt-3 max-w-2xl text-pretty leading-relaxed text-ink-muted">
                      {post.data.description}
                    </p>
                    {post.data.readingTime && (
                      <span class="mt-4 inline-block font-mono text-[0.7rem] uppercase tracking-wider text-ink-faint">
                        {post.data.readingTime}
                      </span>
                    )}
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Base>
